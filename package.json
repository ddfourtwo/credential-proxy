{
  "name": "credential-proxy",
  "version": "1.0.0",
  "description": "MCP server for secure credential management - agents make authenticated requests without seeing credential values",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "credential-proxy": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "credential",
    "proxy",
    "security",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "keytar": "^7.9.0",
    "minimatch": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
